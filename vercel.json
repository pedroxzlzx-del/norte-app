{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/onboarding", "destination": "/onboarding.html" },
    { "source": "/app", "destination": "/app.html" }
  ]
}
